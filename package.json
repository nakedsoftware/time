{
  "name": "@nakedsoftware/time",
  "version": "0.1.0",
  "description": "Naked Time is a time management and time tracking application that helps you to focus on completing important tasks and analyzing how you are using your time",
  "keywords": [
    "naked",
    "pomodoro",
    "productivity",
    "time"
  ],
  "homepage": "https://www.nakedtime.app",
  "bugs": {
