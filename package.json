    "url": "https://github.com/nakedsoftware/time/issues"
  },
  "license": "UNLICENSED",
  "contributors": [
    {
      "name": "Michael Collins",
      "email": "michael.collins@naked.software",
      "url": "https://michaelfcollins3.dev"
    }
  ],
  "repository": "github:nakedsoftware/time",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/cz-commitlint": "^19.8.1",
    "commitizen": "^4.3.1",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": "24.8.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "onFail": "warn",
      "version": "24.8.0"
    }
  },
  "private": true,
  "config": {
    "commitizen": {
      "path": "./node_modules/@commitlint/cz-commitlint"
    }
